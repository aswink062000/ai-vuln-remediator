# =============================================================================
# AI Vulnerability Remediator — Backend Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# --- API Security ---
# Secret key for API authentication (X-API-Key header)
# If not set, authentication is DISABLED (dev mode)
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=

# Encryption key for credential store (SQLite)
# If not set, uses machine-specific fingerprint
ENCRYPTION_SECRET=

# --- GitHub ---
GITHUB_TOKEN=ghp_your_token_here

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# --- LLM Providers (at least one required for Scan & Fix) ---
# Priority: Default → Gemini → Groq → NVIDIA → OpenRouter → HuggingFace

# Default provider (optional — set to prioritize one)
# Options: gemini, gemini-1.5-flash, groq, nvidia, openrouter, huggingface
DEFAULT_LLM_PROVIDER=

# Google Gemini (recommended — fast, free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (extremely fast, generous free tier: 30 req/min)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# NVIDIA NIM
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# OpenRouter (many free models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# HuggingFace (free inference API)
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# --- Webhook ---
# Secret for GitHub webhook signature verification
# Set this in your GitHub webhook settings too
WEBHOOK_SECRET=
